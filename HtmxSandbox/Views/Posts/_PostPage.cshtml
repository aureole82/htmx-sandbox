@model IEnumerable<DbPost>

@foreach (var item in Model)
{
    @await Html.PartialAsync("_PostRow", item)
}
@if (ViewBag.NextPage is not null)
{
    <tr hx-get="@Url.Action("Index", new { page = ViewBag.NextPage })"
        hx-trigger="revealed"
        hx-swap="outerHTML">
        <td colspan="5" class="text-center">
            <div class="spinner-grow" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </td>
    </tr>
}