@model PageModel<DbPost>

@{
    ViewBag.Title = "All Posts";
}

<style>
    /* Start state: The ↑ icon must disappear. */
    .collapse-toggle .bi-arrow-up-square { display: none; }

    /* Open state: Show ↑ icon (close), hide ↓ icon (open). */

    .collapse-toggle[aria-expanded="true"] .bi-arrow-down-square { display: none; }

    .collapse-toggle[aria-expanded="true"] .bi-arrow-up-square { display: inline; }


    /* All table headers should align even on different heights. */

    th { vertical-align: top; }
</style>

<h1>@ViewBag.Title</h1>

<p>
    <button class="btn btn-info btn-sm"
            type="button"
            data-bs-toggle="modal" data-bs-target="#post-modal"
            hx-get="@Url.Action("Create")"
            hx-indicator="#post-modal .modal-body, #post-modal-footer-outlet">
        <i class="bi bi-plus-square"></i> Create New
    </button>
</p>
<table class="table">
    <thead>
    <tr>
        <th>
            @Html.DisplayNameFor(model => model.Items.First().Title)<br/>
            <input class="form-control form-control-sm"
                   name="title"
                   type="text"
                   hx-get="@Url.Action("Index")"
                   hx-include="closest thead"
                   hx-trigger="keyup[keyCode==13], keyup changed delay:500ms">
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Items.First().Content)<br/>
            <input class="form-control form-control-sm"
                   name="content"
                   type="text"
                   hx-get="@Url.Action("Index")"
                   hx-include="closest thead"
                   hx-trigger="keyup[keyCode==13], keyup changed delay:500ms">
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Items.First().Author)<br/>
            <input class="form-control form-control-sm"
                   name="author"
                   type="text"
                   hx-get="@Url.Action("Index")"
                   hx-include="closest thead"
                   hx-trigger="keyup[keyCode==13], keyup changed delay:500ms">
        </th>
        <th>@Html.DisplayNameFor(model => model.Items.First().Created)</th>
        <th></th>
    </tr>
    </thead>
    <tbody>
    @await Html.PartialAsync("_PostPage", Model)
    </tbody>
</table>
<div class="text-center">
    @await Html.PartialAsync("_PagingBar", Model)
</div>
<style>
    /* Collapse spinner completely if no request is running at the moment. */
    #post-modal .htmx-indicator { display: none; }

    /* Show spinner if no request is running at the moment. */

    #post-modal .htmx-request > .htmx-indicator { display: block; }

    /* Hide everything but the spinner if a request is running at the moment. */

    #post-modal .htmx-request > *:not(.htmx-indicator) { display: none; }
</style>

<!-- Multipurpose post modal. -->
<div class="modal fade" id="post-modal" tabindex="-1" aria-labelledby="post-modal-label" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title fs-5" id="post-modal-label">Post Details</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="htmx-indicator text-center">
                    <div class="spinner-border" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
                <div id="post-modal-body-outlet"></div>
            </div>
            <div class="modal-footer d-flex justify-content-between">
                <button class="btn btn-secondary" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i> Cancel</button>
                <div id="post-modal-footer-outlet"></div>
            </div>
        </div>
    </div>
</div>